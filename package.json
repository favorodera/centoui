{
  "name": "centoui-monorepo",
  "version": "1.5.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "description": "Vue components for elegant interfaces",
  "author": "Favour Emeka <favorodera@gmail.com>",
  "license": "MIT",
  "homepage": "https://centoui.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/centoui.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/centoui/issues"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "pnpm lint:root && turbo lint",
    "lint:root": "eslint . --fix --ignore-pattern 'packages/*' --ignore-pattern 'apps/*'",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "postinstall": "turbo postinstall",
    "preview": "turbo preview",
    "prepublishOnly": "turbo prepublishOnly",
    "ready": "pnpm install && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@favorodera/eslint-config": "catalog:tools",
    "@types/node": "catalog:tools",
    "eslint": "catalog:tools",
    "relizy": "catalog:tools",
    "turbo": "catalog:tools",
    "typescript": "catalog:tools"
  }
}
