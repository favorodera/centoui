{
  "name": "centoui-monorepo",
  "version": "0.2.1",
  "description": "Precise vue components",
  "private": true,
  "license": "MIT",
  "author": "Favour Emeka <favorodera@gmail.com>",
  "homepage": "https://centoui.vercel.app/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/centoui.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/centoui/issues"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "lint:root": "eslint . --fix --ignore-pattern 'packages/*' --ignore-pattern 'apps/*'",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:watch": "turbo test:watch",
    "postinstall": "turbo postinstall",
    "preview": "turbo preview",
    "prepublishOnly": "turbo prepublishOnly",
    "ready": "pnpm install && pnpm lint && pnpm typecheck && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.6.0",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-typescript": "^14.7.0",
    "eslint": "^10.2.1",
    "eslint-plugin-better-tailwindcss": "^4.4.1",
    "eslint-plugin-vue": "^10.9.0",
    "relizy": "^1.4.1",
    "turbo": "^2.9.5",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [],
      "allowedVersions": {
        "vite": "8",
        "typescript": "6"
      }
    }
  }
}
