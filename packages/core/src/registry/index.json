{
  "globals": {
    "$schema": "../schemas/globals.json",
    "packageDeps": {
      "tailwindcss": "^4.2.2",
      "@tailwindcss/vite": "^4.2.2",
      "reka-ui": "^2.9.2",
      "tailwind-variants": "^3.2.2",
