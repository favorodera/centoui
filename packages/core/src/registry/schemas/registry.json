{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://centoui.dev/schema/registry.json",
  "title": "Registry",
  "description": "The complete CentoUI registry (index.json).",
  "type": "object",
  "required": [
    "npmDependencies",
    "components"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference URI."
    },
    "npmDependencies": {
      "type": "object",
      "description": "Intentional static list of core NPM packages required in every CentoUI project.",
      "additionalProperties": {
        "type": "string",
        "description": "Semver version range (e.g. '^1.0.0', '~2.3.1', '>=3.0.0').",
        "pattern": "^(\\^|~|>=|>|<=|<|=)?[0-9]+\\.[0-9]+\\.[0-9]+.*$"
      }
    },
    "components": {
      "type": "array",
      "description": "Installable components.",
      "items": {
        "$ref": "./component.json"
      }
    }
  }
}