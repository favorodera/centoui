{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://centoui.dev/schema/component.json",
  "title": "CentoUI component registry entry",
  "description": "Describes a single installable CentoUI component.",
  "type": "object",
  "required": [
    "name",
    "files"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference URI."
    },
    "name": {
      "type": "string",
      "description": "Unique identifier for the component (e.g. 'button').",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "files": {
      "type": "array",
      "description": "Source file paths relative to packages/core/src/components/.",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-/.]*(\\.(vue|ts))$"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "componentDependencies": {
      "type": "array",
      "description": "Names of other CentoUI components required by this one.",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "uniqueItems": true,
      "default": []
    },
    "npmDependencies": {
      "type": "object",
      "description": "NPM packages required by this component.",
      "additionalProperties": {
        "type": "string",
        "description": "Semver version range (e.g. '^1.0.0', '~2.3.1', '>=3.0.0').",
        "pattern": "^(\\^|~|>=|>|<=|<|=)?[0-9]+\\.[0-9]+\\.[0-9]+.*$"
      },
      "default": {}
    }
  }
}