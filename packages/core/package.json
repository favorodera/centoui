{
  "name": "centoui",
  "type": "module",
  "description": "Vue components for elegant interfaces",
  "keywords": [
    "vue",
    "ui",
    "components",
    "tailwindcss",
    "tailwind",
    "design-system",
    "accessibility"
  ],
  "private": false,
  "version": "1.0.0-alpha.34",
  "author": "Favour Emeka <favorodera@gmail.com>",
  "license": "MIT",
  "homepage": "https://centoui.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/centoui.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/centoui/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:registry": "tsx scripts/build-registry.ts",
    "prebuild": "pnpm run build:registry",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:watch": "vitest watch --ui",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "prepublishOnly": "pnpm run build"
  },
  "bin": {
    "centoui": "./bin/centoui.js"
  },
  "dependencies": {
    "centoui-cli": "workspace:*"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@nuxt/icon": "2.2.2",
    "@types/fs-extra": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/ui": "catalog:",
    "@vue/test-utils": "^2.4.8",
    "fs-extra": "catalog:",
    "happy-dom": "^20.9.0",
    "pathe": "catalog:",
    "tsdown": "catalog:",
    "tsx": "^4.21.0",
    "vite": "catalog:",
    "vitest": "catalog:",
    "vitest-axe": "^0.1.0",
    "vue": "catalog:",
    "vue-tsc": "catalog:",
    "@iconify/vue": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "tailwind-variants": "catalog:",
    "tailwind-merge": "catalog:",
    "tw-animate-css": "catalog:",
    "tailwindcss": "catalog:",
    "reka-ui": "catalog:",
    "@vueuse/core": "catalog:"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/vite": "^4.3.0",
    "tailwind-variants": "^3.2.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "tailwindcss": "^4.3.0",
    "reka-ui": "^2.9.6",
    "@vueuse/core": "^14.2.1",
    "@nuxt/icon": "2.2.2"
  },
  "peerDependenciesMeta": {
    "@iconify/vue": {
      "optional": true
    },
    "@nuxt/icon": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  }
}
