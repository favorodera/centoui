{
  "name": "centoui",
  "type": "module",
  "description": "Precise vue components",
  "private": false,
  "version": "1.0.0-alpha.19",
  "author": "Favour Emeka <favorodera@gmail.com>",
  "license": "MIT",
  "homepage": "https://centoui.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/centoui.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/centoui/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:registry": "tsx scripts/build-registry.ts",
    "prebuild": "pnpm run build:registry",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:watch": "vitest watch --ui",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "prepublishOnly": "pnpm run build"
  },
  "bin": {
    "centoui": "./bin/centoui.js"
  },
  "dependencies": {
    "centoui-cli": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@clack/prompts": "^1.2.0",
    "@iconify/vue": "^5.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@types/fs-extra": "^11.0.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/ui": "^4.1.5",
    "@vue/test-utils": "^2.4.8",
    "@vueuse/core": "^14.2.1",
    "fs-extra": "^11.3.4",
    "happy-dom": "^20.9.0",
    "pathe": "^2.0.3",
    "reka-ui": "^2.9.6",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vitest-axe": "^0.1.0",
    "vue": "^3.5.31",
    "vue-tsc": "^3.2.6"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  }
}
