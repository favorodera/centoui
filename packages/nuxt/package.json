{
  "name": "centoui-nuxt",
  "version": "1.0.0-alpha.37",
  "description": "Official Nuxt module for CentoUI",
  "keywords": [
    "nuxt",
    "nuxt-module",
    "vue",
    "ui",
    "components",
    "tailwindcss"
  ],
  "author": "Favour Emeka <favorodera@gmail.com>",
  "license": "MIT",
  "homepage": "https://centoui.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/centoui.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/centoui/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "import": "./dist/module.mjs"
    }
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/types.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "nuxt prepare && nuxt-module-build build --stub",
    "build": "nuxt prepare && nuxt-module-build build",
    "typecheck": "nuxt prepare && vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@nuxt/kit": "^4.4.6",
    "c12": "catalog:",
    "pathe": "catalog:"
  },
  "peerDependencies": {
    "centoui": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^4.4.6",
    "centoui": "workspace:*",
    "nuxt": "catalog:",
    "vue-tsc": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  }
}
