{
  "name": "centoui-cli",
  "type": "module",
  "version": "1.0.0-alpha.34",
  "private": false,
  "description": "Official CLI for CentoUI.",
  "keywords": [
    "cli",
    "vue",
    "ui",
    "components",
    "tailwindcss"
  ],
  "author": "Favour Emeka <favorodera@gmail.com>",
  "license": "MIT",
  "homepage": "https://centoui.vercel.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/favorodera/centoui.git"
  },
  "bugs": {
    "url": "https://github.com/favorodera/centoui/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/types.d.mts",
  "files": [
    "dist"
  ],
  "bin": {
    "centoui": "./dist/index.mjs"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "test:watch": "vitest watch --ui",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --fix",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/fs-extra": "catalog:",
    "@vitest/ui": "catalog:",
    "tsdown": "catalog:",
    "type-fest": "^5.6.0",
    "vitest": "catalog:"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "c12": "catalog:",
    "citty": "^0.2.2",
    "fs-extra": "catalog:",
    "nypm": "^0.6.6",
    "pathe": "catalog:"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  }
}
